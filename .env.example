AGENT_CORE_MODEL=
AGENT_CORE_OPENAI_BASE_URL=
AGENT_CORE_OPENAI_API_KEY=
AGENT_CORE_FALLBACK_MODEL=
AGENT_CORE_FALLBACK_OPENAI_BASE_URL=
AGENT_CORE_FALLBACK_OPENAI_API_KEY=
AGENT_CORE_DATA_DIR=~/.agent-core
AGENT_CORE_CONTEXT_DIR=
AGENT_CORE_CONTEXT_RECENT_MESSAGES=6
AGENT_CORE_CONTEXT_MAX_BLOCK_CHARS=4000

AGENT_CORE_FEISHU_APP_ID=
AGENT_CORE_FEISHU_APP_SECRET=
AGENT_CORE_FEISHU_ALLOWED_OPEN_IDS=
AGENT_CORE_FEISHU_ALLOWED_CHAT_IDS=
AGENT_CORE_FEISHU_REQUIRE_GROUP_MENTION=true
AGENT_CORE_FEISHU_PROCESSING_REACTION=OK
AGENT_CORE_FEISHU_FAILED_REACTION=ERROR

AGENT_CORE_KERNEL_PORT=4130
AGENT_CORE_KERNEL_INGRESS_TIMEOUT_MS=45000
AGENT_CORE_CONNECTOR_PORT=4131
AGENT_CORE_CONNECTOR_EXECUTE_URL=http://127.0.0.1:4131/v1/execute
# Phase 2 M2b: extra operation names granted to every run principal in
# addition to its channel's baseline grant (comma-separated). Each must be a
# name in the operation catalog; unknown names are dropped. Empty (default)
# => principals receive only their channel baseline grant.
AGENT_CORE_EXTRA_ALLOWED_OPERATIONS=
# Phase 2 M2d: when true, risk:Write operations pause the run in
# AwaitingApproval until a human decision resumes it (in-process
# approve_run/deny_run API this increment). Default false: all
# operations inline-approve (backward compatible).
AGENT_CORE_REQUIRE_WRITE_APPROVAL=false
AGENT_CORE_IPC_TOKEN=
